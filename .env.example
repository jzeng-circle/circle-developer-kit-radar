# Optional — increases GitHub API rate limit from 10 to 30 req/min
VITE_GITHUB_TOKEN=

# Optional — Stack Exchange API key (increases quota from 300 to 10,000 req/day)
VITE_STACKEXCHANGE_KEY=

# Tavily Web Search — catches Binance Square, Medium, Mirror.xyz, blogs, press releases
# Get key: https://tavily.com (free: 1000 searches/month, no credit card)
VITE_TAVILY_KEY=

# Google Custom Search Engine (alternative to Tavily)
# Get API key: https://console.cloud.google.com → Custom Search JSON API
# Create CSE:  https://programmablesearchengine.google.com → New search engine → Search the entire web
VITE_GOOGLE_CSE_KEY=
VITE_GOOGLE_CSE_ID=

# NewsAPI — mainstream news outlets
# Get key: https://newsapi.org/register (free: 100 req/day)
VITE_NEWSAPI_KEY=
